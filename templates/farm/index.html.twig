{% extends 'base.html.twig' %}

{% block title %}Fazendas{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Fazendas</h2>
            <a href="{{ path('farm_new') }}" class="btn btn-success">
                + Nova Fazenda
            </a>
        </div>

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Tamanho (ha)</th>
                <th>Responsável</th>
                <th>Veterinários</th>
                <th>Ações</th>
            </tr>
            </thead>
            <tbody>
            {% for farm in pagination %}
                <tr>
                    <td>{{ farm.name }}</td>
                    <td>{{ farm.tamanho }}</td>
                    <td>{{ farm.responsavel }}</td>
                    <td>
                        {% for vet in farm.veterinarios %}
                            <span class="badge bg-success">{{ vet.name }}</span>
                        {% else %}
                            <span class="text-muted">Nenhum</span>
                        {% endfor %}
                    </td>
                    <td>
                        <a href="{{ path('farm_edit', {id: farm.id}) }}" class="btn btn-sm btn-warning">Editar</a>
                        <form method="post" action="{{ path('farm_delete', {id: farm.id}) }}" class="d-inline"
                              onsubmit="return confirm('Confirmar a exclusão')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-farm-' ~ farm.id) }}">
                            <button class="btn btn-sm btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center">Nenhuma fazenda cadastrada.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="d-flex justify-content-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    </div>
{% endblock %}