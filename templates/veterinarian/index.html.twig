{% extends 'base.html.twig' %}

{% block title %}Veterinários{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Veterinários</h2>
            <a href="{{ path('veterinarian_new') }}" class="btn btn-success">
                 Novo Veterinário
            </a>
        </div>

        <form method="get" class="mb-3">
            <div class="input-group" style="max-width: 380px">
                <input type="text" name="search" class="form-control"
                       placeholder="Buscar por nome ou CRMV" value="{{ search }}">
                <button class="btn btn-outline-secondary" type="submit">
                    <i class="bi bi-search"></i>
                </button>
                {% if search %}
                    <a href="{{ path('veterinarian_index') }}" class="btn btn-outline-danger">
                        <i class="bi bi-x"></i>
                    </a>
                {% endif %}
            </div>
        </form>

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>CRMV</th>
                <th>Ações</th>
            </tr>
            </thead>
            <tbody>
            {% for vet in pagination %}
                <tr>
                    <td>{{ vet.name }}</td>
                    <td>{{ vet.crmv }}</td>
                    <td>
                        <a href="{{ path('veterinarian_edit', {id: vet.id}) }}" class="btn btn-sm btn-warning">Editar</a>
                        <form method="post" action="{{ path('veterinarian_delete', {id: vet.id}) }}" class="d-inline"
                              data-confirm="Deseja excluir o veterinário {{ vet.name }}?">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-vet-' ~ vet.id) }}">
                            <button class="btn btn-sm btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center">Nenhum veterinário cadastrado</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="d-flex justify-content-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    </div>
{% endblock %}