{% extends 'base.html.twig' %}

{% block title %}Veterinários{% endblock %}

{% block body %}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Veterinários</h2>
        <a href="{{ path('veterinarian_new') }}" class="btn btn-success">
            + Novo Veterinário
        </a>
    </div>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
        <tr>
            <th>Nome</th>
            <th>CRMV</th>
            <th>Ações</th>
        </tr>
        </thead>
        <tbody>
        {% for vet in pagination %}
            <tr>
                <td>{{ vet.name }}</td>
                <td>{{ vet.crmv }}</td>
                <td>
                    <a href="{{ path('veterinarian_edit', {id: vet.id}) }}" class="btn btn-sm btn-warning">Editar</a>
                    <form method="post" action="{{ path('veterinarian_delete', {id: vet.id}) }}" class="d-inline"
                          onsubmit="return confirm('Confirmar a exclusão')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-vet-' ~ vet.id) }}">
                        <button class="btn btn-sm btn-danger">Excluir</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3" class="text-center">Nenhum veterinário cadastrado</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="d-flex justify-content-center">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>

{% endblock %}
