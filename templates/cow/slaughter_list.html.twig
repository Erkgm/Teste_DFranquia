{% extends 'base.html.twig' %}

{% block title %}Lista de Abate{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="text-danger">Lista de Abate</h2>
            <span class="badge bg-danger fs-6">{{ eligible|length }} animais</span>
        </div>

        {% if eligible|length == 0 %}
            <div class="alert alert-success">
                Nenhum animal pronto para abate
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Fazenda</th>
                        <th>Nascimento / Idade</th>
                        <th>Leite (L/sem)</th>
                        <th>Ração (kg/dia)</th>
                        <th>Peso (@)</th>
                        <th>Motivos</th>
                        <th>Ação</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in eligible %}
                        <tr>
                            <td><span class="badge bg-danger">{{ item.cow.code }}</span></td>
                            <td>{{ item.cow.farm.name }}</td>
                            <td>
                                {{ item.cow.birthDate|date('d/m/Y') }}
                                <br><small class="text-muted">{{ item.cow.ageInYears|number_format(1, ',', '.') }} anos</small>
                            </td>
                            <td>{{ item.cow.milkFloat|number_format(2, ',', '.') }}</td>
                            <td>{{ item.cow.rationPerDay|number_format(2, ',', '.') }}</td>
                            <td>{{ item.cow.weightInArrobas|number_format(2, ',', '.') }}@</td>
                            <td>
                                {% for reason in item.reasons %}
                                    <span class="badge bg-warning text-dark d-block mb-1">{{ reason }}</span>
                                {% endfor %}
                            </td>
                            <td>
                                <form method="post" action="{{ path('cow_slaughter', {id: item.cow.id}) }}"
                                      data-confirm="Confirma o abate do animal {{ item.cow.code }}?">
                                    <input type="hidden" name="_token" value="{{ csrf_token('slaughter-' ~ item.cow.id) }}">
                                    <button class="btn btn-sm btn-danger">Abater</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
{% endblock %}