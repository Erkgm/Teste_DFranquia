{% extends 'base.html.twig' %}

{% block title %}Animais{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Animais</h2>
            <a href="{{ path('cow_new') }}" class="btn btn-success">
                + Novo Animal
            </a>
        </div>

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
            <tr>
                <th>Código</th>
                <th>Fazenda</th>
                <th>Nascimento</th>
                <th>Leite (L/sem)</th>
                <th>Ração (kg/sem)</th>
                <th>Peso (kg)</th>
                <th>Ações</th>
            </tr>
            </thead>
            <tbody>
            {% for cow in pagination %}
                <tr>
                    <td>{{ cow.code }}</td>
                    <td>{{ cow.farm.name }}</td>
                    <td>{{ cow.birthDate|date('d/m/Y') }}</td>
                    <td>{{ cow.milkLitersPerWeek|number_format(2, ',', '.') }}</td>
                    <td>{{ cow.rationKgPerWeek|number_format(2, ',', '.') }}</td>
                    <td>{{ cow.weightKg|number_format(2, ',', '.') }}</td>
                    <td>
                        <a href="{{ path('cow_edit', {id: cow.id}) }}" class="btn btn-sm btn-warning">Editar</a>
                        <form method="post" action="{{ path('cow_delete', {id: cow.id}) }}" class="d-inline"
                              data-confirm="Deseja excluir o animal {{ cow.code }}?">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-cow-' ~ cow.id) }}">
                            <button class="btn btn-sm btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center">Nenhum animal cadastrado</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="d-flex justify-content-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    </div>
{% endblock %}