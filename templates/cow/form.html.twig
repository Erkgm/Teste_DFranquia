{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="card">
                    <div class="card-header">
                        <h4>{{ title }}</h4>
                    </div>
                    <div class="card-body">
                        {{ form_start(form, {'action': cow is defined ? path('cow_edit', {id: cow.id}) : path('cow_new'), 'method': 'POST'}) }}
                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_label(form.codigo) }}
                                {{ form_widget(form.codigo) }}
                                {{ form_errors(form.codigo) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_label(form.dataNascimento) }}
                                {{ form_widget(form.dataNascimento) }}
                                {{ form_errors(form.dataNascimento) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_label(form.litrosLeitePorSemana) }}
                                {{ form_widget(form.litrosLeitePorSemana) }}
                                {{ form_errors(form.litrosLeitePorSemana) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_label(form.racaoPorSemana) }}
                                {{ form_widget(form.racaoPorSemana) }}
                                {{ form_errors(form.racaoPorSemana) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_label(form.peso) }}
                                {{ form_widget(form.peso) }}
                                {{ form_errors(form.peso) }}
                            </div>
                            <div class="col-12">
                                {{ form_label(form.fazenda) }}
                                {{ form_widget(form.fazenda) }}
                                {{ form_errors(form.fazenda) }}
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success">Salvar</button>
                            <a href="{{ path('cow_index') }}" class="btn btn-secondary">Cancelar</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}